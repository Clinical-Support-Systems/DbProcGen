<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="2.1.0" />
  <PropertyGroup>
    <Name>DbProcGen.Database</Name>
    <DSP>Microsoft.Data.Tools.Schema.Sql.Sql170DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
    <ProjectGuid>8FE91EAA-850A-4F33-955C-7DD8E1B26719</ProjectGuid>
    <EnableDefaultSqlItems>false</EnableDefaultSqlItems>
  </PropertyGroup>

  <ItemGroup>
    <Build Include="Schema\**\*.sql" />
